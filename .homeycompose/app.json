{
  "id": "com.trashchecker",
  "sdk": 3,
  "name": {
    "en": "Trashcan Reminder 2.0",
    "nl": "Afval Herinnering 2.0",
    "sv": "Avfallspåminnelse 2.0",
    "fr": "Rappel de collecte 2.0"
  },
  "version": "5.9.1",
  "platforms": [
    "local"
  ],
  "compatibility": ">=12.3.0",
  "author": {
    "name": "Robert Raaijmakers",
    "email": "dutchfighter@live.nl"
  },
  "brandColor": "#006622",
  "permissions": [],
  "contributors": {
    "developers": [
      {
        "name": "Robert Raaijmakers",
        "email": "dutchfighter@live.nl"
      }
    ]
  },
  "description": {
    "en": "Use this app to check when your trash will be collected",
    "nl": "Gebruik deze app om erachter te komen wanneer uw afval wordt opgehaald"
  },
  "category": "tools",
  "images": {
    "small": "./assets/images/small.png",
    "large": "./assets/images/large.png",
    "xlarge": "./assets/images/xlarge.png"
  },
  "contributing": {
    "donate": {
      "paypal": {
        "username": "RobertRaaijmakers"
      }
    }
  },
  "bugs": {
    "url": "https://github.com/robertraaijmakers/com.trashchecker/issues"
  },
  "homepage": "https://robertraaijmakers.github.io/com.trashchecker/",
  "support": "https://robertraaijmakers.github.io/com.trashchecker/",
  "homeyCommunityTopicId": 114178,
  "source": "https://github.com/robertraaijmakers/com.trashchecker",
  "api": {
    "validateUserData": {
      "method": "POST",
      "path": "/trashcollection"
    },
    "validateUserCleanData": {
      "method": "POST",
      "path": "/clean"
    },
    "trashCollectionDays": {
      "method": "GET",
      "path": "/trashcollectiondays"
    }
  },
  "drivers": [
    {
      "name": {
        "en": "Collection Address",
        "nl": "Ophaaladres",
        "sv": "Hamtadress",
        "fr": "Adresse de collecte"
      },
      "images": {
        "large": "drivers/trash_address/assets/images/large.png",
        "small": "drivers/trash_address/assets/images/small.png"
      },
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "class": "other",
      "capabilities": [],
      "pair": [
        {
          "id": "enter_api_settings"
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "prev": "enter_api_settings",
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "repair": [
        {
          "id": "reconfigure_api_settings"
        }
      ]
    }
  ]
}